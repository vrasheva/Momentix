@inherits LayoutComponentBase
@implements IDisposable
@inject AuthSession Auth

@{
    var isAuthPage = Nav.Uri.Contains("/login") || Nav.Uri.Contains("/register");
}

@if (isAuthPage)
{
    @Body
}
else
{
    <div class="app-shell" style="--theme:@Auth.ThemeHex;--theme-light:@(Auth.ThemeHex)22;--theme-text:@Auth.ThemeHex;--sidebar-bg:@Auth.ThemeHex;">
        <aside class="app-sidebar">
            <NavMenu />
        </aside>

        <main class="app-main">
            <header class="app-topbar">
                <div class="topbar-crumb">
                    @if (Auth.IsLoggedIn)
                    {
                        <a href="/profile" class="topbar-av" title="Профил">@Initials</a>
                    }
                    Momentix › <span>@PageTitle</span>
                </div>

                @if (Auth.IsLoggedIn)
                {
                    <a href="/profile" class="user-chip">
                        <span class="user-chip-av">@Initials</span>
                        <span class="user-chip-name">@Auth.FullName</span>
                    </a>
                }
            </header>

            <section class="app-content">
                @Body
            </section>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    Възникна грешка.
    <a href="." class="reload">Презареди</a>
    <span class="dismiss">×</span>
</div>

@code {
    private string PageTitle => Nav?.Uri?.TrimEnd('/') switch
    {
        var u when u.EndsWith("albums") => "Албуми",
        var u when u.EndsWith("capsules") => "Капсули",
        var u when u.EndsWith("friends") => "Приятели",
        var u when u.EndsWith("challenges") => "Предизвикателства",
        var u when u.EndsWith("profile") => "Профил",
        var u when u.EndsWith("notifications") => "Известия",
        _ => "Momentix"
    };

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string Initials => string.IsNullOrWhiteSpace(Auth.FullName)
        ? "?"
        : string.Join(string.Empty,
            Auth.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2).Select(p => char.ToUpperInvariant(p[0])));

    protected override void OnInitialized()
    {
        Auth.Changed += OnAuthChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _ = InvokeAsync(StateHasChanged);
    }

    private void OnAuthChanged() => _ = InvokeAsync(StateHasChanged);
    private void OnLocationChanged(object? s, LocationChangedEventArgs e) => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.Changed -= OnAuthChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}