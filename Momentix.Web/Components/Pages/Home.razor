@page "/"
@inject AuthSession Auth
@inject MomentixApiClient Api

<div class="page-header">
    <div>
        <h1 class="page-title">Momentix workspace</h1>
        <p class="page-description">Manage albums, time capsules, friends and photo challenges from the browser.</p>
    </div>
</div>

@if (!Auth.IsLoggedIn)
{
    <div class="grid two">
        <section class="panel">
            <h2 class="section-title">Continue to your memories</h2>
            <p class="muted">Use the same account as the Android app. The web version talks to the same API and database.</p>
            <div class="actions">
                <a class="primary-button" href="login">Login</a>
                <a class="secondary-button" href="register">Create account</a>
            </div>
        </section>
        <section class="panel">
            <h2 class="section-title">Available here</h2>
            <div class="badge-row">
                <span class="badge">Albums</span>
                <span class="badge gold">Time capsules</span>
                <span class="badge coral">Friends</span>
                <span class="badge">Challenges</span>
            </div>
        </section>
    </div>
}
else
{
    <div class="grid three">
        <a class="card-link" href="albums">
            <article class="card">
                <div class="eyebrow">Albums</div>
                <h2 class="section-title">Photo albums</h2>
                <p class="muted">Create, open, share and upload memories.</p>
                <div class="badge-row"><span class="badge">@albumCount visible</span></div>
            </article>
        </a>
        <a class="card-link" href="capsules">
            <article class="card">
                <div class="eyebrow">Time Capsules</div>
                <h2 class="section-title">Locked memories</h2>
                <p class="muted">Add photos and invite friends before unlock time.</p>
                <div class="badge-row"><span class="badge gold">@capsuleCount visible</span></div>
            </article>
        </a>
        <a class="card-link" href="challenges">
            <article class="card">
                <div class="eyebrow">Challenge</div>
                <h2 class="section-title">Daily game</h2>
                <p class="muted">Upload a photo and vote on others.</p>
                <div class="badge-row"><span class="badge coral">Play</span></div>
            </article>
        </a>
    </div>
}

@code {
    private int albumCount;
    private int capsuleCount;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
            return;

        var albums = await Api.GetAsync<List<AlbumResponseDto>>("Albums");
        var capsules = await Api.GetAsync<List<TimeCapsuleResponseDto>>("TimeCapsule");
        albumCount = albums?.Count ?? 0;
        capsuleCount = capsules?.Count ?? 0;
    }
}
