@page "/challenges"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<h1 class="page-title">Предизвикателства</h1>
<p class="page-subtitle">Качи снимка за дневното предизвикателство и гласувай за другите.</p>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="error-message">@error</div>
}
@if (!string.IsNullOrWhiteSpace(status))
{
    <div class="badge mb-16">@status</div>
}

@if (isLoading)
{
    <div class="empty-state">Зареждане на предизвикателството...</div>
}
else if (challenge == null)
{
    <div class="empty-state">Няма активно предизвикателство.</div>
}
else
{
    <div class="challenges-top">
        <div class="card">
            <div class="flex-between mb-12">
                <span class="challenge-day-tag">Дневно предизвикателство</span>
                <button class="btn-sm" type="button" @onclick="() => LoadChallenge()">
                    <i class="ti ti-refresh"></i> Обнови
                </button>
            </div>
            <div class="challenge-title">@challenge.Description</div>
            <div class="challenge-reveal">Разкриване: @challenge.RevealAt.ToLocalTime().ToString("dd.MM.yyyy")<br />@challenge.RevealAt.ToLocalTime().ToString("HH:mm")</div>

            <label class="upload-area" style="display:block">
                <i class="ti ti-camera"></i>
                @(challengePhoto == null ? "Избери снимка за предизвикателството" : $"Избрано: {challengePhoto.Name}")
                <InputFile OnChange="OnChallengePhotoSelected" accept="image/*" style="display:none" />
            </label>

            <button class="btn-primary full-width" type="button" @onclick="SubmitPhoto" disabled="@(isBusy || challengePhoto == null)">
                @(isBusy ? "Качване..." : "Изпрати снимка")
            </button>

            @if (Auth.IsAdmin)
            {
                <button class="btn-danger mt-12" type="button" @onclick="ResetChallenge" disabled="@isBusy">Нулирай предизвикателството</button>
            }
        </div>

        <div class="card">
            <div class="section-label">Опции за гласуване</div>
            <p class="page-subtitle" style="margin-bottom:0">Познай темата на предизвикателството.</p>
            <div class="vote-options">
                @foreach (var option in voteOptions)
                {
                    <span class="vote-chip">@option</span>
                }
            </div>
        </div>
    </div>

    <div class="feed-section-title">Публикации</div>
    @if (submissions.Count == 0)
    {
        <div class="empty-state">Няма публикации все още.</div>
    }
    else
    {
        <div class="albums-grid">
            @foreach (var submission in submissions)
            {
                <div class="card" style="padding:0;overflow:hidden">
                    @if (!string.IsNullOrWhiteSpace(submission.MediaUrl))
                    {
                        <div class="album-photo" style="aspect-ratio:1">
                            <img src="@Api.ToBrowserUrl(submission.MediaUrl)" alt="Снимка на участник" style="width:100%;height:100%;object-fit:cover" />
                        </div>
                    }
                    <div style="padding:10px">
                        <div class="flex-between mb-4">
                            <div class="album-name">@submission.UserName</div>
                            @if (submission.UserId == Auth.UserId)
                            {
                                <button class="album-delete-btn" title="Изтрий участие" type="button"
                                        style="position:static;opacity:1;width:24px;height:24px;font-size:12px"
                                        @onclick="() => DeleteSubmission(submission.Id)">
                                    <i class="ti ti-trash"></i>
                                </button>
                            }
                        </div>
                        <div class="album-meta">@submission.VoteCount гласа</div>
                        <div class="vote-options mt-8">
                            <span class="@GetAiBadgeClass(submission)">@GetAiLabel(submission)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(submission.AiFeedback))
                        {
                            <div class="album-meta mt-8">@submission.AiFeedback</div>
                        }
                        <div class="vote-options mt-12">
                            @foreach (var option in voteOptions)
                            {
                                <span class="vote-chip" @onclick="() => Vote(submission.Id, option)">@option</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private readonly string[] voteOptions = { "Зелено", "Блестящо", "Животно", "Любим детайл" };
    private ChallengeResponseDto? challenge;
    private List<ChallengeSubmissionResponseDto> submissions = new();
    private IBrowserFile? challengePhoto;
    private bool isLoading = true;
    private bool isBusy;
    private string? error;
    private string? status;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadChallenge();
    }

    private async Task LoadChallenge()
    {
        await LoadChallenge(clearMessages: true);
    }

    private async Task LoadChallenge(bool clearMessages)
    {
        isLoading = true;
        if (clearMessages)
        {
            error = null;
            status = null;
        }

        challenge = await Api.GetAsync<ChallengeResponseDto>("Challenges/active");
        if (challenge != null)
            submissions = await Api.GetAsync<List<ChallengeSubmissionResponseDto>>($"Challenges/{challenge.Id}/submissions") ?? new();
        else
            error = Api.LastError;

        isLoading = false;
    }

    private void OnChallengePhotoSelected(InputFileChangeEventArgs e)
    {
        challengePhoto = e.File;
        error = null;
        status = null;
    }

    private async Task SubmitPhoto()
    {
        if (challenge == null || challengePhoto == null)
            return;

        isBusy = true;
        error = null;
        status = "Качване и проверка на снимката с AI...";
        StateHasChanged();

        var result = await Api.PostFileAsync<ChallengeSubmissionResponseDto>($"Challenges/{challenge.Id}/submissions/photo", challengePhoto);
        if (result == null)
        {
            error = Api.LastError ?? "Снимката не беше изпратена.";
            status = null;
            isBusy = false;
            return;
        }

        challengePhoto = null;
        status = BuildSubmitStatus(result);
        await LoadChallenge(clearMessages: false);
        isBusy = false;
    }

    private async Task ResetChallenge()
    {
        if (!Auth.IsAdmin)
            return;

        isBusy = true;
        error = null;
        status = null;

        var ok = await Api.PostAsync("Challenges/admin/reset-active");
        if (!ok)
        {
            error = Api.LastError ?? "Предизвикателството не беше нулирано.";
            isBusy = false;
            return;
        }

        challengePhoto = null;
        submissions.Clear();
        status = "Предизвикателството е нулирано. Всички снимки бяха изтрити.";
        await LoadChallenge(clearMessages: false);
        isBusy = false;
    }

    private async Task DeleteSubmission(int id)
    {
        var ok = await Api.DeleteAsync($"Challenges/submissions/{id}");
        if (!ok)
            error = Api.LastError ?? "Участието не беше изтрито.";
        else
            await LoadChallenge(clearMessages: false);
    }

    private async Task Vote(int submissionId, string option)
    {
        isBusy = true;
        error = null;
        status = null;

        var ok = await Api.PostAsync($"Challenges/submissions/{submissionId}/vote", new CreateChallengeVoteDto
        {
            SelectedOption = option
        });

        if (!ok)
        {
            error = Api.LastError ?? "Гласът не беше записан.";
            isBusy = false;
            return;
        }

        status = "Гласът е записан.";
        await LoadChallenge(clearMessages: false);
        isBusy = false;
    }

    private static string BuildSubmitStatus(ChallengeSubmissionResponseDto submission)
    {
        if (submission.AiIsSatisfied == true)
            return $"Снимката е изпратена. AI смята, че съвпада ({FormatConfidence(submission)}).";

        if (submission.AiIsSatisfied == false)
            return $"Снимката е изпратена. AI смята, че не съвпада ({FormatConfidence(submission)}).";

        return string.IsNullOrWhiteSpace(submission.AiFeedback)
            ? "Снимката е изпратена. AI проверката не беше възможна."
            : $"Снимката е изпратена. {submission.AiFeedback}";
    }

    private static string GetAiLabel(ChallengeSubmissionResponseDto submission)
    {
        if (submission.AiIsSatisfied == true)
            return $"AI: съвпада {FormatConfidence(submission)}";

        if (submission.AiIsSatisfied == false)
            return $"AI: не съвпада {FormatConfidence(submission)}";

        return submission.AiEvaluatedAt.HasValue || !string.IsNullOrWhiteSpace(submission.AiFeedback)
            ? "AI: недостъпен"
            : "AI: непроверена";
    }

    private static string GetAiBadgeClass(ChallengeSubmissionResponseDto submission)
    {
        if (submission.AiIsSatisfied == true)
            return "badge badge-green";

        if (submission.AiIsSatisfied == false)
            return "badge badge-red";

        return "badge badge-amber";
    }

    private static string FormatConfidence(ChallengeSubmissionResponseDto submission) =>
        submission.AiConfidence.HasValue ? $"{submission.AiConfidence.Value}%" : "без оценка";
}
