@page "/capsules"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<h1 class="page-title">Капсули</h1>
<p class="page-subtitle">Заключи снимки за бъдеща дата и сподели капсулата с приятели.</p>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="error-message">@error</div>
}
@if (!string.IsNullOrWhiteSpace(status))
{
    <div class="badge mb-16">@status</div>
}

@if (isLoading)
{
    <div class="empty-state">Зареждане на капсули...</div>
}
else
{
    <div class="albums-section">
        <div class="section-header">
            <div class="section-label" style="margin-bottom:0">Моите капсули</div>
            <span class="section-count">@myCapsules.Count</span>
        </div>
        <div class="capsules-grid">
            <div class="create-card" @onclick="OpenCreate">
                <i class="ti ti-plus"></i>
                <span>Добави капсула</span>
            </div>
            @foreach (var capsule in myCapsules)
            {
                <div class="album-card-wrap">
                    @RenderCapsuleCard(capsule)
                    <button class="album-delete-btn" title="Изтрий капсула" type="button"
                            @onclick="() => DeleteCapsule(capsule.Id)">
                        <i class="ti ti-trash"></i>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="albums-section">
        <div class="section-header">
            <div class="section-label" style="margin-bottom:0">Споделени с мен</div>
            <span class="section-count">@sharedCapsules.Count</span>
        </div>
        @if (sharedCapsules.Count == 0)
        {
            <div class="empty-state">Няма споделени с теб капсули.</div>
        }
        else
        {
            <div class="capsules-grid">
                @foreach (var capsule in sharedCapsules)
                {
                    @RenderCapsuleCard(capsule)
                }
            </div>
        }
    </div>
}

@if (showCreateForm)
{
    <div class="modal-overlay" @onclick="CancelCreate">
        <div class="modal-box" style="max-width:600px" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span class="modal-title">Нова капсула</span>
                <button class="btn-sm" type="button" @onclick="CancelCreate">
                    <i class="ti ti-x"></i>
                </button>
            </div>

            <EditForm Model="newCapsule" OnValidSubmit="CreateCapsule" class="form-stack">

                <div class="field">
                    <label>Заглавие</label>
                    <InputText class="input" @bind-Value="newCapsule.Title" placeholder="Заглавие на капсулата" />
                </div>

                <div class="field">
                    <label>Описание</label>
                    <InputTextArea class="input" @bind-Value="newCapsule.Description" placeholder="Кратко описание..." />
                </div>

                <div class="capsule-form-grid" style="margin-top:0">
                    <div class="field">
                        <label>Дата на отключване</label>
                        <input type="date" class="input" value="@unlockDate" @onchange="OnUnlockDateChanged" />
                    </div>
                    <div class="field">
                        <label>Час на отключване</label>
                        <input type="time" class="input" value="@unlockTime" @onchange="OnUnlockTimeChanged" />
                    </div>
                </div>

                <div class="field">
                    <label>Снимки</label>
                    <InputFile OnChange="OnCapsuleFilesSelected" accept="image/*" multiple class="input" />
                    @if (selectedFiles.Count > 0)
                    {
                        <span class="album-meta">Избрани: @selectedFiles.Count снимки</span>
                    }
                </div>

                @if (friendSelections.Count > 0)
                {
                    <div class="field">
                        <label>Покани приятели</label>
                        @foreach (var friend in friendSelections)
                        {
                            <div class="friend-row" style="padding:10px 0">
                                <span class="friend-av">@Initials(friend.FullName)</span>
                                <div class="friend-info">
                                    <div class="friend-name">@friend.FullName</div>
                                    <div class="friend-email">@friend.Email</div>
                                </div>
                                <div class="friend-actions">
                                    <label class="d-flex gap-8" style="font-size:12px;cursor:pointer">
                                        <input type="checkbox" @bind="friend.IsSelected" />
                                        Покани
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="d-flex gap-8 mt-16">
                    <button class="btn-primary" type="submit" disabled="@isBusy">
                        @(isBusy ? "Създаване..." : "Създай капсула")
                    </button>
                    <button class="btn-secondary" type="button" @onclick="CancelCreate">Откажи</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private readonly CreateTimeCapsuleDto newCapsule = new();
    private List<TimeCapsuleResponseDto> capsules = new();
    private List<TimeCapsuleResponseDto> myCapsules = new();
    private List<TimeCapsuleResponseDto> sharedCapsules = new();
    private List<FriendSelection> friendSelections = new();
    private IReadOnlyList<IBrowserFile> selectedFiles = Array.Empty<IBrowserFile>();
    private string unlockDate = DateTime.Today.AddDays(1).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string unlockTime = "22:00";
    private bool isLoading = true;
    private bool isBusy;
    private bool showCreateForm;
    private string? error;
    private string? status;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        capsules = await Api.GetAsync<List<TimeCapsuleResponseDto>>("TimeCapsule") ?? new();
        myCapsules = capsules.Where(c => c.IsOwner).ToList();
        sharedCapsules = capsules.Where(c => !c.IsOwner).ToList();

        var friends = await Api.GetAsync<List<FriendResponseDto>>("Friends") ?? new();
        friendSelections = friends.Select(f => new FriendSelection(f)).ToList();
        isLoading = false;
    }

    private async Task DeleteCapsule(int id)
    {
        var ok = await Api.DeleteAsync($"TimeCapsule/{id}");
        if (!ok)
            error = Api.LastError ?? "Капсулата не беше изтрита.";
        else
            await LoadData();
    }

    private void OpenCreate()
    {
        showCreateForm = true;
        error = null;
        status = null;
    }

    private void CancelCreate()
    {
        showCreateForm = false;
        ResetForm();
    }

    private void OnUnlockDateChanged(ChangeEventArgs e) => unlockDate = e.Value?.ToString() ?? string.Empty;
    private void OnUnlockTimeChanged(ChangeEventArgs e) => unlockTime = e.Value?.ToString() ?? string.Empty;

    private void OnCapsuleFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles(12);
    }

    private async Task CreateCapsule()
    {
        if (string.IsNullOrWhiteSpace(newCapsule.Title))
        {
            error = "Заглавието на капсулата е задължително.";
            return;
        }

        if (!DateTime.TryParseExact($"{unlockDate} {unlockTime}", "yyyy-MM-dd HH:mm",
            CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var unlockLocal))
        {
            error = "Невалидна дата или час за отключване.";
            return;
        }

        isBusy = true;
        error = null;
        status = null;
        newCapsule.UnlockAt = unlockLocal.ToUniversalTime();

        var created = await Api.PostAsync<CreateTimeCapsuleDto, TimeCapsuleResponseDto>("TimeCapsule", newCapsule);
        if (created == null)
        {
            error = Api.LastError ?? "Капсулата не беше създадена.";
            isBusy = false;
            return;
        }

        foreach (var friend in friendSelections.Where(f => f.IsSelected))
        {
            await Api.PostAsync($"TimeCapsule/{created.Id}/members", new AddAlbumMemberDto
            {
                UserEmail = friend.Email,
                CanUpload = false
            });
        }

        foreach (var file in selectedFiles)
        {
            await Api.PostFileAsync<MediaResponseDto>($"Media/timecapsule/{created.Id}/photo", file);
        }

        showCreateForm = false;
        status = "Капсулата е създадена.";
        ResetForm();
        await LoadData();
        isBusy = false;
    }

    private void ResetForm()
    {
        newCapsule.Title = string.Empty;
        newCapsule.Description = string.Empty;
        selectedFiles = Array.Empty<IBrowserFile>();
        unlockDate = DateTime.Today.AddDays(1).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        unlockTime = "22:00";
        foreach (var f in friendSelections)
            f.IsSelected = false;
    }

    private RenderFragment RenderCapsuleCard(TimeCapsuleResponseDto capsule) => @<a class="capsule-card @(capsule.IsUnlocked ? "unlocked" : "locked")" href="@($"capsules/{capsule.Id}")">
        <i class="ti @(capsule.IsUnlocked ? "ti-lock-open" : "ti-lock") capsule-bg-icon"></i>
        <div class="capsule-status">@(capsule.IsUnlocked ? "Готова" : "Заключена")</div>
        <div>
            <div class="capsule-name">@capsule.Title</div>
            <div class="capsule-date">@capsule.UnlockAt.ToLocalTime().ToString("dd.MM.yyyy")</div>
            <div class="capsule-count">@capsule.MediaCount снимки</div>
        </div>
    </a>;

    private static string Initials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][0].ToString().ToUpper() : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private sealed class FriendSelection
    {
        public FriendSelection(FriendResponseDto f) { FullName = f.FullName; Email = f.Email; }
        public string FullName { get; }
        public string Email { get; }
        public bool IsSelected { get; set; }
    }
}
