@page "/friends"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<h1 class="page-title">Приятели</h1>
<p class="page-subtitle">Намирай потребители, изпращай заявки и приемай покани.</p>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="error-message">@error</div>
}
@if (!string.IsNullOrWhiteSpace(status))
{
    <div class="badge mb-16">@status</div>
}

<div class="friends-layout">
    <div>
        <div class="card">
            <div class="section-label">Моите приятели</div>
            @if (friends.Count == 0)
            {
                <div class="empty-state">Все още нямаш приятели.</div>
            }
            else
            {
                @foreach (var friend in friends)
                {
                    <div class="friend-row">
                        <span class="friend-av">@Initials(friend.FullName)</span>
                        <div class="friend-info">
                            <div class="friend-name">@friend.FullName</div>
                            <div class="friend-email">@friend.Email</div>
                        </div>
                        <div class="friend-actions">
                            <button class="btn-sm" type="button" @onclick="() => RemoveFriend(friend.UserId)">Премахни</button>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="card mb-16">
            <div class="section-label">Получени заявки</div>
            @if (incomingRequests.Count == 0)
            {
                <div class="empty-state">Няма получени заявки.</div>
            }
            else
            {
                @foreach (var request in incomingRequests)
                {
                    <div class="friend-row">
                        <span class="friend-av">@Initials(request.RequesterName)</span>
                        <div class="friend-info">
                            <div class="friend-name">@request.RequesterName</div>
                            <div class="friend-email">@request.RequesterEmail</div>
                        </div>
                        <div class="friend-actions">
                            <button class="btn-theme-sm" type="button" @onclick="() => AcceptRequest(request.Id)">Приеми</button>
                            <button class="btn-sm" type="button" @onclick="() => DeclineRequest(request.Id)">Откажи</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="card">
        <div class="section-label">Намери потребители</div>
        <div class="search-row">
            <input class="input" placeholder="Търси по име или имейл" @bind="search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
            <button class="btn-primary" type="button" @onclick="SearchUsers" disabled="@isBusy">Търси</button>
        </div>

        @if (users.Count == 0)
        {
            <div class="empty-state">Няма намерени потребители.</div>
        }
        else
        {
            @foreach (var user in users)
            {
                <div class="friend-row">
                    <span class="friend-av">@Initials(user.FullName)</span>
                    <div class="friend-info">
                        <div class="friend-name">@user.FullName</div>
                        <div class="friend-email">@user.Email</div>
                    </div>
                    <div class="friend-actions">
                        @if (user.IsFriend)
                        {
                            <span class="badge-green badge">Приятел</span>
                        }
                        else if (user.HasPendingOutgoingRequest)
                        {
                            <span class="badge-amber badge">Изчаква</span>
                        }
                        else if (user.HasPendingIncomingRequest && user.IncomingRequestId.HasValue)
                        {
                            <button class="btn-theme-sm" type="button" @onclick="() => AcceptRequest(user.IncomingRequestId.Value)">Приеми</button>
                        }
                        else
                        {
                            <button class="btn-sm" type="button" @onclick="() => SendRequest(user.UserId)">Добави</button>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<FriendResponseDto> friends = new();
    private List<FriendRequestResponseDto> incomingRequests = new();
    private List<UserSearchResponseDto> users = new();
    private string search = string.Empty;
    private bool isBusy;
    private string? error;
    private string? status;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadAll();
    }

    private async Task LoadAll()
    {
        error = null;
        friends = await Api.GetAsync<List<FriendResponseDto>>("Friends") ?? new();
        incomingRequests = await Api.GetAsync<List<FriendRequestResponseDto>>("Friends/requests/incoming") ?? new();
        await SearchUsers();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SearchUsers();
    }

    private async Task SearchUsers()
    {
        isBusy = true;
        error = null;
        users = await Api.GetAsync<List<UserSearchResponseDto>>($"Friends/users?search={Uri.EscapeDataString(search)}") ?? new();
        if (Api.LastError != null)
            error = Api.LastError;
        isBusy = false;
    }

    private async Task SendRequest(string userId)
    {
        await RunAction(async () => await Api.PostAsync($"Friends/requests/{userId}"), "Заявката е изпратена.");
    }

    private async Task AcceptRequest(int requestId)
    {
        await RunAction(async () => await Api.PostAsync($"Friends/requests/{requestId}/accept"), "Заявката е приета.");
    }

    private async Task DeclineRequest(int requestId)
    {
        await RunAction(async () => await Api.PostAsync($"Friends/requests/{requestId}/decline"), "Заявката е отказана.");
    }

    private async Task RemoveFriend(string userId)
    {
        await RunAction(async () => await Api.DeleteAsync($"Friends/{userId}"), "Приятелят е премахнат.");
    }

    private async Task RunAction(Func<Task<bool>> action, string successMessage)
    {
        isBusy = true;
        error = null;
        status = null;

        var ok = await action();
        if (!ok)
        {
            error = Api.LastError ?? "Действието не беше изпълнено.";
            isBusy = false;
            return;
        }

        status = successMessage;
        await LoadAll();
        isBusy = false;
    }

    private static string Initials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "?";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}
