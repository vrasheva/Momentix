@page "/albums/{AlbumId:int}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<div class="flex-between mb-16">
    <div>
        <h1 class="page-title" style="margin-bottom:0">@(album?.Title ?? "Албум")</h1>
        <p class="page-subtitle" style="margin-bottom:0">@(album?.Description ?? "Снимки и писма, споделени в този албум.")</p>
    </div>
    <a class="btn-secondary" href="albums">Назад</a>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="error-message">@error</div>
}
@if (!string.IsNullOrWhiteSpace(status))
{
    <div class="badge mb-16">@status</div>
}

@if (isLoading)
{
    <div class="empty-state">Зареждане на албума...</div>
}
else if (album == null)
{
    <div class="empty-state">Албумът не е намерен.</div>
}
else
{
    <div class="friends-layout">
        <div class="card">
            <div class="section-label">Добави спомен</div>
            <div class="form-stack">
                <div class="field">
                    <label>Снимка</label>
                    <InputFile OnChange="OnPhotoSelected" accept="image/*" />
                    @if (photoFile != null)
                    {
                        <span class="album-meta">Избрано: @photoFile.Name</span>
                    }
                </div>
                <button class="btn-primary" type="button" @onclick="UploadPhoto" disabled="@(isBusy || photoFile == null)">Качи снимка</button>

                <div class="field mt-16">
                    <label>Писмо</label>
                    <InputTextArea class="input" @bind-Value="letter.Text" placeholder="Напиши писмо..." />
                </div>
                <button class="btn-secondary" type="button" @onclick="AddLetter" disabled="@isBusy">Добави писмо</button>
            </div>
        </div>

        <div class="card">
            <div class="section-label">Хора</div>
            @foreach (var member in members)
            {
                <div class="friend-row">
                    <span class="friend-av" style="background:@(member.AvatarColor)33;color:@member.AvatarColor">@member.Initials</span>
                    <div class="friend-info">
                        <div class="friend-name">@member.FullName</div>
                        <div class="friend-email">@member.RoleText</div>
                    </div>
                </div>
            }

            @if (CanShare)
            {
                <div class="field mt-16">
                    <label>Сподели с приятел</label>
                    <select class="input" @bind="selectedFriendEmail">
                        <option value="">Избери приятел</option>
                        @foreach (var friend in friends)
                        {
                            <option value="@friend.Email">@friend.FullName (@friend.Email)</option>
                        }
                    </select>
                </div>
                <label class="d-flex gap-8 mb-16">
                    <input type="checkbox" @bind="shareCanUpload" />
                    <span>Може да качва снимки</span>
                </label>
                <button class="btn-primary" type="button" @onclick="ShareAlbum" disabled="@(isBusy || string.IsNullOrWhiteSpace(selectedFriendEmail))">Сподели албум</button>
            }
        </div>
    </div>

    <div class="albums-section">
        <div class="section-label">Спомени</div>
        @if (media.Count == 0)
        {
            <div class="empty-state">Няма снимки или писма все още.</div>
        }
        else
        {
            <div class="albums-grid">
                @foreach (var item in media)
                {
                    <div class="card" style="padding:0;overflow:hidden;display:flex;flex-direction:column">
                        @if (item.Type == MediaType.Image)
                        {
                            <div class="album-photo" style="aspect-ratio:1">
                                <img src="@Api.ToBrowserUrl(item.Url)" alt="Спомен от албума" style="width:100%;height:100%;object-fit:cover" />
                            </div>
                        }
                        else if (item.Type == MediaType.Letter)
                        {
                            <div style="padding:10px;flex:1">@item.Url</div>
                        }
                        else
                        {
                            <div style="padding:10px">Неподдържан вид съдържание: @item.Type</div>
                        }
                        <div style="padding:10px">
                            <div class="album-meta">от @item.UploadedByName</div>
                            <button class="btn-danger mt-8" type="button" @onclick="() => DeleteMedia(item.Id)">Изтрий</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public int AlbumId { get; set; }

    private AlbumResponseDto? album;
    private List<MediaResponseDto> media = new();
    private List<AlbumMemberResponseDto> members = new();
    private List<FriendResponseDto> friends = new();
    private readonly CreateLetterMediaDto letter = new();
    private IBrowserFile? photoFile;
    private string selectedFriendEmail = string.Empty;
    private bool shareCanUpload = true;
    private bool isLoading = true;
    private bool isBusy;
    private string? error;
    private string? status;

    private bool CanShare => members.Any(member => member.IsOwner && member.UserId == Auth.UserId);

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadAlbum();
    }

    private async Task LoadAlbum()
    {
        isLoading = true;
        error = null;

        album = await Api.GetAsync<AlbumResponseDto>($"Albums/{AlbumId}");
        if (album == null)
        {
            error = Api.LastError;
            isLoading = false;
            return;
        }

        media = await Api.GetAsync<List<MediaResponseDto>>($"Media/album/{AlbumId}") ?? new();
        members = await Api.GetAsync<List<AlbumMemberResponseDto>>($"Albums/{AlbumId}/members") ?? new();
        friends = await Api.GetAsync<List<FriendResponseDto>>("Friends") ?? new();
        isLoading = false;
    }

    private void OnPhotoSelected(InputFileChangeEventArgs e)
    {
        photoFile = e.File;
        status = null;
        error = null;
    }

    private async Task UploadPhoto()
    {
        if (photoFile == null)
            return;

        isBusy = true;
        error = null;
        status = null;

        var uploaded = await Api.PostFileAsync<MediaResponseDto>($"Media/album/{AlbumId}/photo", photoFile);
        if (uploaded == null)
        {
            error = Api.LastError ?? "Снимката не беше качена.";
            isBusy = false;
            return;
        }

        media.Insert(0, uploaded);
        photoFile = null;
        status = "Снимката е качена.";
        isBusy = false;
    }

    private async Task AddLetter()
    {
        if (string.IsNullOrWhiteSpace(letter.Text))
        {
            error = "Текстът на писмото е задължителен.";
            return;
        }

        isBusy = true;
        error = null;
        status = null;

        var created = await Api.PostAsync<CreateLetterMediaDto, MediaResponseDto>($"Media/album/{AlbumId}/letter", letter);
        if (created == null)
        {
            error = Api.LastError ?? "Писмото не беше добавено.";
            isBusy = false;
            return;
        }

        media.Insert(0, created);
        letter.Text = string.Empty;
        status = "Писмото е добавено.";
        isBusy = false;
    }

    private async Task ShareAlbum()
    {
        isBusy = true;
        error = null;
        status = null;

        var ok = await Api.PostAsync($"Albums/{AlbumId}/members", new AddAlbumMemberDto
        {
            UserEmail = selectedFriendEmail,
            CanUpload = shareCanUpload
        });

        if (!ok)
        {
            error = Api.LastError ?? "Албумът не беше споделен.";
            isBusy = false;
            return;
        }

        selectedFriendEmail = string.Empty;
        status = "Албумът е споделен.";
        await LoadAlbum();
        isBusy = false;
    }

    private async Task DeleteMedia(int id)
    {
        var ok = await Api.DeleteAsync($"Media/{id}");
        if (!ok)
        {
            error = Api.LastError ?? "Съдържанието не беше изтрито.";
            return;
        }

        media.RemoveAll(item => item.Id == id);
        status = "Съдържанието е изтрито.";
    }
}
