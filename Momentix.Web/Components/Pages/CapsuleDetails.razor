@page "/capsules/{CapsuleId:int}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<div class="flex-between mb-16">
    <div>
        <h1 class="page-title" style="margin-bottom:0">@(capsule?.Title ?? "Капсула")</h1>
        <p class="page-subtitle" style="margin-bottom:0">@(capsule?.Description ?? "Заключени спомени за бъдещ момент.")</p>
    </div>
    <a class="btn-secondary" href="capsules">Назад</a>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="error-message">@error</div>
}
@if (!string.IsNullOrWhiteSpace(status))
{
    <div class="badge mb-16">@status</div>
}

@if (isLoading)
{
    <div class="empty-state">Зареждане на капсулата...</div>
}
else if (capsule == null)
{
    <div class="empty-state">Капсулата не е намерена.</div>
}
else
{
    <div class="friends-layout">
        <div class="card">
            <div class="section-label">Статус</div>
            @if (capsule.IsUnlocked)
            {
                <span class="badge badge-green">Отключена</span>
                <p class="album-meta mt-8">Съдържанието на капсулата вече е видимо.</p>
            }
            else
            {
                <span class="badge badge-amber">@FormatRemaining(capsule.UnlockAt)</span>
                <p class="album-meta mt-8">Отключва се на @capsule.UnlockAt.ToLocalTime().ToString("dd.MM.yyyy") в @capsule.UnlockAt.ToLocalTime().ToString("HH:mm")</p>
            }

            @if (capsule.IsOwner)
            {
                <div class="field mt-16">
                    <label>Добави снимка в капсулата</label>
                    <InputFile OnChange="OnPhotoSelected" accept="image/*" />
                    @if (photoFile != null)
                    {
                        <span class="album-meta">Избрано: @photoFile.Name</span>
                    }
                </div>
                <button class="btn-primary" type="button" @onclick="UploadPhoto" disabled="@(isBusy || photoFile == null)">Качи снимка</button>
            }
        </div>

        <div class="card">
            <div class="section-label">Хора</div>
            @foreach (var member in members)
            {
                <div class="friend-row">
                    <span class="friend-av" style="background:@(member.AvatarColor)33;color:@member.AvatarColor">@member.Initials</span>
                    <div class="friend-info">
                        <div class="friend-name">@member.FullName</div>
                        <div class="friend-email">@(member.IsOwner ? "Собственик" : "Може да преглежда")</div>
                    </div>
                </div>
            }

            @if (capsule.IsOwner)
            {
                <div class="field mt-16">
                    <label>Сподели с приятел</label>
                    <select class="input" @bind="selectedFriendEmail">
                        <option value="">Избери приятел</option>
                        @foreach (var friend in friends)
                        {
                            <option value="@friend.Email">@friend.FullName (@friend.Email)</option>
                        }
                    </select>
                </div>
                <button class="btn-primary" type="button" @onclick="ShareCapsule" disabled="@(isBusy || string.IsNullOrWhiteSpace(selectedFriendEmail))">Сподели капсула</button>
            }
        </div>
    </div>

    <div class="albums-section">
        <div class="section-label">Спомени в капсулата</div>
        @if (!capsule.IsUnlocked)
        {
            <div class="empty-state">Съдържанието е скрито до момента на отключване.</div>
        }
        else if (media.Count == 0)
        {
            <div class="empty-state">Все още няма снимки в тази капсула.</div>
        }
        else
        {
            <div class="albums-grid">
                @foreach (var item in media)
                {
                    <div class="card" style="padding:0;overflow:hidden;display:flex;flex-direction:column">
                        @if (item.Type == MediaType.Image)
                        {
                            <div class="album-photo" style="aspect-ratio:1">
                                <img src="@Api.ToBrowserUrl(item.Url)" alt="Спомен от капсулата" style="width:100%;height:100%;object-fit:cover" />
                            </div>
                        }
                        else
                        {
                            <div style="padding:10px;flex:1">@item.Url</div>
                        }
                        <div style="padding:10px">
                            <div class="album-meta">от @item.UploadedByName</div>
                            @if (capsule.IsOwner)
                            {
                                <button class="btn-danger mt-8" type="button" @onclick="() => DeleteMedia(item.Id)">Изтрий</button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public int CapsuleId { get; set; }

    private TimeCapsuleResponseDto? capsule;
    private List<MediaResponseDto> media = new();
    private List<AlbumMemberResponseDto> members = new();
    private List<FriendResponseDto> friends = new();
    private IBrowserFile? photoFile;
    private string selectedFriendEmail = string.Empty;
    private bool isLoading = true;
    private bool isBusy;
    private string? error;
    private string? status;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadCapsule();
    }

    private async Task LoadCapsule()
    {
        isLoading = true;
        error = null;

        capsule = await Api.GetAsync<TimeCapsuleResponseDto>($"TimeCapsule/{CapsuleId}");
        if (capsule == null)
        {
            error = Api.LastError;
            isLoading = false;
            return;
        }

        members = await Api.GetAsync<List<AlbumMemberResponseDto>>($"TimeCapsule/{CapsuleId}/members") ?? new();
        friends = await Api.GetAsync<List<FriendResponseDto>>("Friends") ?? new();

        if (capsule.IsUnlocked)
            media = await Api.GetAsync<List<MediaResponseDto>>($"Media/timecapsule/{CapsuleId}") ?? new();

        isLoading = false;
    }

    private void OnPhotoSelected(InputFileChangeEventArgs e)
    {
        photoFile = e.File;
        error = null;
        status = null;
    }

    private async Task UploadPhoto()
    {
        if (photoFile == null)
            return;

        isBusy = true;
        error = null;
        status = null;

        var uploaded = await Api.PostFileAsync<MediaResponseDto>($"Media/timecapsule/{CapsuleId}/photo", photoFile);
        if (uploaded == null)
        {
            error = Api.LastError ?? "Снимката не беше добавена.";
            isBusy = false;
            return;
        }

        if (capsule?.IsUnlocked == true)
            media.Insert(0, uploaded);

        photoFile = null;
        status = "Снимката е добавена в капсулата.";
        isBusy = false;
    }

    private async Task ShareCapsule()
    {
        isBusy = true;
        error = null;
        status = null;

        var ok = await Api.PostAsync($"TimeCapsule/{CapsuleId}/members", new AddAlbumMemberDto
        {
            UserEmail = selectedFriendEmail,
            CanUpload = false
        });

        if (!ok)
        {
            error = Api.LastError ?? "Капсулата не беше споделена.";
            isBusy = false;
            return;
        }

        selectedFriendEmail = string.Empty;
        status = "Капсулата е споделена.";
        await LoadCapsule();
        isBusy = false;
    }

    private async Task DeleteMedia(int id)
    {
        var ok = await Api.DeleteAsync($"Media/{id}");
        if (!ok)
        {
            error = Api.LastError ?? "Съдържанието не беше изтрито.";
            return;
        }

        media.RemoveAll(item => item.Id == id);
        status = "Съдържанието е изтрито.";
    }

    private static string FormatRemaining(DateTime unlockAt)
    {
        var remaining = unlockAt.ToLocalTime() - DateTime.Now;
        if (remaining <= TimeSpan.Zero)
            return "Готова за отваряне";

        return $"{(int)remaining.TotalDays}д {remaining.Hours}ч {remaining.Minutes}м";
    }
}
