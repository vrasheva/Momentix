@page "/register"
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<div class="auth-wrap">
    <section class="auth-panel">
        <h1 class="page-title">Register</h1>
        <p class="page-description">Create a Momentix account for albums, capsules and challenges.</p>

        <EditForm Model="model" OnValidSubmit="DoRegister" class="form-stack">
            <div class="field">
                <label>Full name</label>
                <InputText class="input" @bind-Value="model.FullName" />
            </div>
            <div class="field">
                <label>Email</label>
                <InputText class="input" @bind-Value="model.Email" type="email" />
            </div>

            <button class="secondary-button full-width" type="button" @onclick="SendRegistrationEmail" disabled="@(isBusy || isSendingEmail)">
                @(isSendingEmail ? "Sending email..." : "Send test email")
            </button>

            @if (!string.IsNullOrWhiteSpace(emailStatus))
            {
                <div class="status-message">@emailStatus</div>
            }

            <div class="field">
                <label>Password</label>
                <InputText class="input" @bind-Value="model.Password" type="password" />
            </div>
            <div class="field">
                <label>Theme color</label>
                <input type="color" @bind="model.ThemeColor" />
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="error-message">@error</div>
            }

            <button class="primary-button full-width" type="submit" disabled="@isBusy">@(isBusy ? "Creating..." : "Create account")</button>
            <a class="secondary-button full-width" href="login">I already have an account</a>
        </EditForm>
    </section>
</div>

@code {
    private readonly RegisterDto model = new() { ThemeColor = "#167a72" };
    private bool isBusy;
    private bool isSendingEmail;
    private string? error;
    private string? emailStatus;

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Nav.NavigateTo("/albums");
    }

    private async Task SendRegistrationEmail()
    {
        isSendingEmail = true;
        error = null;
        emailStatus = null;

        var ok = await Api.PostAsync("Auth/send-registration-email", new SendRegistrationEmailDto
        {
            Email = model.Email,
            FullName = model.FullName
        });

        if (ok)
            emailStatus = "Test email sent.";
        else
            error = Api.LastError ?? "Email could not be sent.";

        isSendingEmail = false;
    }

    private async Task DoRegister()
    {
        isBusy = true;
        error = null;

        var response = await Api.PostAsync<RegisterDto, AuthResponseDto>("Auth/register", model);
        if (response == null)
        {
            error = Api.LastError ?? "Registration failed.";
            isBusy = false;
            return;
        }

        Auth.SignIn(response);
        Nav.NavigateTo("/albums");
    }
}
