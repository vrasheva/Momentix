@page "/register"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSession Auth
@inject MomentixApiClient Api
@inject NavigationManager Nav

<div class="auth-shell">
    <div class="auth-left">
        <div class="auth-collage">
            <img src="images/auth/flatlay-desk.jpg" alt="" />
            <img class="tall" src="images/auth/polaroids-pile.jpg" alt="" />
            <img src="images/auth/bw-photos.jpg" alt="" />
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrap">
            <div class="auth-left-logo">
                <span class="logo-mark" style="background:@model.ThemeColor">M</span>
                <span class="auth-left-logo-name">Momentix</span>
            </div>
            <div class="auth-tagline-title">Създай своя акаунт.</div>
            <div class="auth-tagline-desc">Избери тема, която те следва навсякъде в приложението.</div>

            <div class="auth-form-title">Регистрация</div>
            <div class="auth-form-sub">Създай Momentix акаунт за албуми, капсули и предизвикателства.</div>

            <EditForm Model="model" OnValidSubmit="DoRegister" class="auth-form-stack">
                <div class="field">
                    <label>Пълно име</label>
                    <InputText class="input" @bind-Value="model.FullName" placeholder="Твоето име" />
                </div>
                <div class="field">
                    <label>Имейл</label>
                    <InputText class="input" @bind-Value="model.Email" type="text" placeholder="email@example.com" />
                </div>
                <div class="field">
                    <label>Парола</label>
                    <InputText class="input" @bind-Value="model.Password" type="password" placeholder="••••••••" />
                </div>
                <div class="field">
                    <label>Цвят на темата</label>
                    <div class="theme-picker theme-picker-plain">
                        @foreach (var t in Themes)
                        {
                            <div class="theme-dot-wrap" @onclick="() => SelectTheme(t.Hex)">
                                <div class="theme-dot @(model.ThemeColor == t.Hex ? "active" : "")"
                                     style="background:@t.Hex"></div>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="error-message">@error</div>
                }

                <button class="btn-primary full-width" type="submit"
                        style="background:@model.ThemeColor"
                        disabled="@isBusy">
                    @(isBusy ? "Регистриране..." : "Регистрирай се")
                </button>
                <div class="auth-divider"></div>
                <a class="btn-secondary full-width" href="login">Вече имам акаунт</a>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private readonly RegisterDto model = new() { ThemeColor = "#111111" };
    private bool isBusy;
    private string? error;

    private static readonly (string Hex, string Name)[] Themes =
    [
        ("#378ADD", "Синя"),
        ("#7F77DD", "Лилава"),
        ("#1D9E75", "Зелена"),
        ("#EF9F27", "Жълта"),
        ("#111111", "Тъмна"),
    ];

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Nav.NavigateTo("/albums");
    }

    private void SelectTheme(string hex) => model.ThemeColor = hex;

    private async Task DoRegister()
    {
        isBusy = true;
        error = null;

        var response = await Api.PostAsync<RegisterDto, AuthResponseDto>("Auth/register", model);
        if (response == null)
        {
            error = Api.LastError ?? "Грешка при регистрация.";
            isBusy = false;
            return;
        }

        Auth.SignIn(response);
        Nav.NavigateTo("/albums");
    }
}