<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.TimeCapsuleDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="White"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,14" BackgroundColor="White">
            <Grid WidthRequest="36" HeightRequest="36">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}"/>
                </Grid.GestureRecognizers>
                <Ellipse Stroke="#E0E0E0" StrokeThickness="1.5" Fill="Transparent"
                         WidthRequest="36" HeightRequest="36"
                         HorizontalOptions="Center" VerticalOptions="Center"/>
                <Path Data="M 20,18 L 15,12 L 20,6" Stroke="#111" StrokeThickness="2"
                      StrokeLineCap="Round" StrokeLineJoin="Round"
                      WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Start" VerticalOptions="Center">
                    <Path.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Path.GestureRecognizers>
                </Path>
            </Grid>
            <Label Grid.Column="1" Text="{Binding CapsuleTitle}"
                   FontSize="15" FontAttributes="Bold" TextColor="#111"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" Color="Transparent"/>
        </Grid>

        <BoxView Grid.Row="0" HeightRequest="0.5" BackgroundColor="#F0F0F0" VerticalOptions="End"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Countdown карта -->
                <Border Margin="16,16,16,0" Padding="20"
                        BackgroundColor="{Binding CountdownCardColor}"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Border BackgroundColor="{Binding BadgeColor}" Padding="10,4"
                                HorizontalOptions="Start" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding StatusText}" FontSize="12"
                                   FontAttributes="Bold" TextColor="White"/>
                        </Border>

                        <Label Text="{Binding Description}" FontSize="14"
                               TextColor="#555555" IsVisible="{Binding HasDescription}"/>

                        <Label Text="{Binding CountdownText}" FontSize="36" FontAttributes="Bold"
                               TextColor="#111111" IsVisible="{Binding IsLocked}"/>
                        <Label Text="Ready to open" FontSize="28" FontAttributes="Bold"
                               TextColor="#111111" IsVisible="{Binding IsUnlocked}"/>

                        <Label Text="{Binding UnlockDateText}" FontSize="12" TextColor="#555555"/>

                        <Label Text="{Binding MediaCount, StringFormat='{0} снимки'}"
                               FontSize="12" TextColor="#555555" IsVisible="{Binding IsUnlocked}"/>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="8" BackgroundColor="#F7F7F7" Margin="0,16"/>

                <!-- Членове -->
                <Grid ColumnDefinitions="*,Auto" Padding="16,0,16,12">
                    <Label Text="Членове" FontSize="13" FontAttributes="Bold"
                           TextColor="#111" VerticalOptions="Center"/>
                    <Border Grid.Column="1" BackgroundColor="{DynamicResource PrimaryLight}"
                            Padding="12,6" StrokeThickness="0" IsVisible="{Binding IsOwner}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenAddMemberPopupCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="+ Добави" FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}"/>
                    </Border>
                </Grid>

                <CollectionView ItemsSource="{Binding Members}" Margin="16,0,16,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,8">
                                <Border Grid.Column="0" BackgroundColor="{Binding AvatarColor}"
                                        WidthRequest="40" HeightRequest="40">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Initials}" FontSize="14" FontAttributes="Bold"
                                           TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding FullName}" FontSize="13" FontAttributes="Bold" TextColor="#111"/>
                                    <Label Text="{Binding RoleText}" FontSize="11" TextColor="#888"/>
                                </VerticalStackLayout>
                                <Image Grid.Column="2" Source="crown.svg" WidthRequest="16" HeightRequest="16"
                                       VerticalOptions="Center" IsVisible="{Binding IsOwner}"/>
                                <BoxView Grid.ColumnSpan="3" HeightRequest="0.5"
                                         BackgroundColor="#F5F5F5" VerticalOptions="End"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout IsVisible="{Binding IsOwner}" Margin="16,8,16,0">
                    <Label Text="{Binding StatusMessage}" TextColor="#E24B4A" FontSize="12"
                           HorizontalOptions="Center"
                           IsVisible="{Binding StatusMessage, Converter={StaticResource StringToBoolConverter}}"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="8" BackgroundColor="#F7F7F7" Margin="0,16"/>

                <!-- Снимки -->
                <VerticalStackLayout IsVisible="{Binding IsUnlocked}" Margin="16,0,16,24" Spacing="12">
                    <Label Text="Снимки" FontSize="13" FontAttributes="Bold" TextColor="#111"/>
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                       Color="{DynamicResource Primary}"/>
                    <CollectionView ItemsSource="{Binding MediaItems}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2"
                                             HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Няма снимки в тази капсула." Padding="0,24"
                                   HorizontalTextAlignment="Center" TextColor="#888" FontSize="13"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border HeightRequest="160" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding Url}" Aspect="AspectFill"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Заключена -->
                <VerticalStackLayout IsVisible="{Binding IsLocked}"
                                     Margin="16,0,16,32" HorizontalOptions="Center" Spacing="8">
                    <Image Source="hourglass.svg" WidthRequest="48" HeightRequest="48"
                           HorizontalOptions="Center"/>
                    <Label Text="Снимките ще се появят след отключването."
                           FontSize="13" TextColor="#888888" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Popup: Добави член -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              IsVisible="{Binding IsAddMemberPopupVisible}"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseAddMemberPopupCommand}"/>
            </Grid.GestureRecognizers>
            <Border BackgroundColor="White" StrokeThickness="0"
                    VerticalOptions="Center" HorizontalOptions="Fill" Margin="24,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPopupContentTapped"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="16" Padding="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Добави член" FontSize="17" FontAttributes="Bold"
                               TextColor="#111" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="✕" Command="{Binding CloseAddMemberPopupCommand}"
                                BackgroundColor="#F3F4F6" TextColor="#888888" FontSize="13" CornerRadius="15"
                                WidthRequest="30" HeightRequest="30" Padding="0"/>
                    </Grid>
                    <CollectionView x:Name="FriendPickerList" ItemsSource="{Binding Friends}"
                                    HeightRequest="250" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="Няма приятели за добавяне." HorizontalTextAlignment="Center"
                                   TextColor="#888" FontSize="13" Padding="0,16"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,8">
                                    <Border Grid.Column="0" BackgroundColor="{Binding AvatarColor}"
                                            WidthRequest="38" HeightRequest="38">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="19"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Initials}" FontSize="13" FontAttributes="Bold"
                                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding FullName}" FontAttributes="Bold" FontSize="13" TextColor="#111"/>
                                        <Label Text="{Binding Email}" FontSize="11" TextColor="#888"/>
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2" Text="Добави"
                                            Command="{Binding BindingContext.AddSelectedFriendCommand, Source={x:Reference FriendPickerList}}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{DynamicResource Primary}" TextColor="White"
                                            FontSize="11" CornerRadius="10" Padding="10,6" VerticalOptions="Center"/>
                                    <BoxView Grid.ColumnSpan="3" HeightRequest="0.5"
                                             BackgroundColor="#F5F5F5" VerticalOptions="End"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>