<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.TimeCapsuleDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Capsule"
    BackgroundColor="{DynamicResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button
                    Text="Back"
                    Command="{Binding BackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{DynamicResource Primary}" />
                <Label
                    Grid.Column="1"
                    Text="{Binding CapsuleTitle}"
                    FontSize="26"
                    FontAttributes="Bold"
                    VerticalOptions="Center"
                    TextColor="{DynamicResource TextPrimary}" />
            </Grid>

            <Border
                Padding="16"
                BackgroundColor="{DynamicResource CardBackground}"
                StrokeThickness="1"
                Stroke="{DynamicResource BorderColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="{Binding StatusText}"
                        FontSize="14"
                        TextColor="{DynamicResource Primary}" />
                    <Label
                        Text="{Binding Description}"
                        FontSize="15"
                        TextColor="{DynamicResource TextSecondary}" />
                    <Label
                        Text="{Binding CountdownText}"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#386A20" />
                    <Label
                        Text="{Binding UnlockDateText}"
                        FontSize="13"
                        TextColor="{DynamicResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>


            <VerticalStackLayout
                Spacing="10"
                IsVisible="{Binding IsOwner}">
                <Label
                    Text="Share capsule"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="{DynamicResource TextPrimary}" />
                <Border
                    Padding="10,0"
                    BackgroundColor="{DynamicResource CardBackground}"
                    StrokeThickness="1"
                    Stroke="{DynamicResource BorderColor}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Picker
                        Title="Choose friend"
                        ItemsSource="{Binding Friends}"
                        SelectedItem="{Binding SelectedFriend}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        HeightRequest="46"
                        TextColor="{DynamicResource TextPrimary}"
                        TitleColor="{DynamicResource TextSecondary}"
                        BackgroundColor="Transparent" />
                </Border>
                <Button
                    Text="Share with friend"
                    Command="{Binding AddSelectedFriendCommand}"
                    BackgroundColor="{DynamicResource Primary}"
                    TextColor="White"
                    HeightRequest="46"
                    CornerRadius="12"
                    FontAttributes="Bold" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label
                    Text="People"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="{DynamicResource TextPrimary}" />
                <VerticalStackLayout
                    Spacing="0"
                    BindableLayout.ItemsSource="{Binding Members}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,8">
                                <Border
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    BackgroundColor="{DynamicResource PrimaryLight}"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Label
                                        Text="{Binding Initials}"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="{DynamicResource PrimaryText}"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label
                                        Text="{Binding FullName}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="{DynamicResource TextPrimary}" />
                                    <Label
                                        Text="{Binding RoleText}"
                                        FontSize="12"
                                        TextColor="{DynamicResource TextSecondary}" />
                                </VerticalStackLayout>
                                <Label
                                    Grid.Column="2"
                                    Text="Owner"
                                    FontSize="12"
                                    TextColor="{DynamicResource Primary}"
                                    VerticalOptions="Center"
                                    IsVisible="{Binding IsOwner}" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>            <Label
                Text="{Binding StatusMessage}"
                TextColor="{DynamicResource Primary}" />

            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="{DynamicResource Primary}" />

            <Label
                Text="Photos"
                FontSize="20"
                FontAttributes="Bold"
                IsVisible="{Binding IsUnlocked}"
                TextColor="{DynamicResource TextPrimary}" />

            <Label
                Text="Photos will appear here when the capsule unlocks."
                IsVisible="{Binding IsLocked}"
                TextColor="{DynamicResource TextSecondary}" />

            <CollectionView
                ItemsSource="{Binding MediaItems}"
                IsVisible="{Binding IsUnlocked}">
                <CollectionView.EmptyView>
                    <Label
                        Text="No photos in this capsule."
                        Padding="0,24"
                        HorizontalTextAlignment="Center"
                        TextColor="{DynamicResource TextSecondary}" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="12"
                            Margin="0,6"
                            BackgroundColor="{DynamicResource CardBackground}"
                            StrokeThickness="1"
                            Stroke="{DynamicResource BorderColor}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Image
                                    Source="{Binding Url}"
                                    IsVisible="{Binding IsImage}"
                                    Aspect="AspectFill"
                                    HeightRequest="240"
                                    BackgroundColor="{DynamicResource PageBackground}" />
                                <Label
                                    Text="{Binding UploadedByName, StringFormat='By: {0}'}"
                                    FontSize="13"
                                    TextColor="{DynamicResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
