<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="0" VerticalOptions="Center"
                         MinimumHeightRequest="600">

            <Label Text="Momentix" FontSize="42" FontAttributes="Bold,Italic"
                   TextColor="#111111" CharacterSpacing="-1" Margin="0,0,0,4"/>

            <Label Text="Създай акаунт" FontSize="14"
                   TextColor="#888888" Margin="0,0,0,36"/>

            <Label Text="Пълно име" FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" Margin="0,0,0,6"/>
            <Border BackgroundColor="White" StrokeThickness="1"
                    Stroke="#E0E0E0" Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Placeholder="Твоето ime" Text="{Binding FullName}"
                       HeightRequest="46" Margin="8,0"
                       TextColor="#111111" PlaceholderColor="#BBBBBB"
                       BackgroundColor="Transparent"/>
            </Border>

            <Label Text="Имейл" FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" Margin="0,0,0,6"/>
            <Border BackgroundColor="White" StrokeThickness="1"
                    Stroke="#E0E0E0" Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Placeholder="email@example.com" Text="{Binding UserEmail}"
                       Keyboard="Email" HeightRequest="46" Margin="8,0"
                       TextColor="#111111" PlaceholderColor="#BBBBBB"
                       BackgroundColor="Transparent"/>
            </Border>

            <Label Text="Парола" FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" Margin="0,0,0,6"/>
            <Border BackgroundColor="White" StrokeThickness="1"
                    Stroke="#E0E0E0" Margin="0,0,0,24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Entry Placeholder="••••••••" Text="{Binding UserPassword}"
                       IsPassword="True" HeightRequest="46" Margin="8,0"
                       TextColor="#111111" PlaceholderColor="#BBBBBB"
                       BackgroundColor="Transparent"/>
            </Border>

            <Label Text="Избери своята тема" FontSize="11" FontAttributes="Bold"
                   TextColor="#888888" Margin="0,0,0,12"/>

            <HorizontalStackLayout Spacing="12" Margin="0,0,0,28">
                <Border WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#60A5FA"
                        StrokeThickness="{Binding SelectedTheme, Converter={StaticResource ThemeToStrokeConverter}, ConverterParameter=Blue}"
                        Stroke="#111111">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}" CommandParameter="Blue"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#34D399"
                        StrokeThickness="{Binding SelectedTheme, Converter={StaticResource ThemeToStrokeConverter}, ConverterParameter=Green}"
                        Stroke="#111111">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}" CommandParameter="Green"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#FBBF24"
                        StrokeThickness="{Binding SelectedTheme, Converter={StaticResource ThemeToStrokeConverter}, ConverterParameter=Yellow}"
                        Stroke="#111111">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}" CommandParameter="Yellow"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#A78BFA"
                        StrokeThickness="{Binding SelectedTheme, Converter={StaticResource ThemeToStrokeConverter}, ConverterParameter=Purple}"
                        Stroke="#111111">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}" CommandParameter="Purple"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#1F2937"
                        StrokeThickness="{Binding SelectedTheme, Converter={StaticResource ThemeToStrokeConverter}, ConverterParameter=Black}"
                        Stroke="#60A5FA">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}" CommandParameter="Black"/>
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>

            <Label Text="{Binding ErrorMessage}" TextColor="#E24B4A"
                   FontSize="12" HorizontalOptions="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                   Margin="0,0,0,8"/>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{DynamicResource Primary}"
                               Margin="0,0,0,8"/>

            <Button Text="Регистрирай се" Command="{Binding RegisterCommand}"
                    BackgroundColor="#111111" TextColor="White"
                    HeightRequest="50" CornerRadius="12"
                    FontAttributes="Bold" FontSize="14"
                    HorizontalOptions="Fill"
                    Margin="0,0,0,16"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Имаш акаунт?" FontSize="13"
                       TextColor="#888888" VerticalOptions="Center"/>
                <Label Text="Влез" FontSize="13" FontAttributes="Bold"
                       TextColor="{DynamicResource Primary}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>