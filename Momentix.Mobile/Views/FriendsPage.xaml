<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.FriendsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Friends"
    BackgroundColor="{DynamicResource PageBackground}">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="16">
        <VerticalStackLayout Spacing="2">
            <Label Text="Friends" FontSize="28" FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}" />
            <Label Text="People you can quickly add to shared albums"
                   FontSize="13" TextColor="{DynamicResource TextSecondary}" />
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" Command="{Binding LoadFriendsCommand}"
                     IsRefreshing="{Binding IsLoading}">
            <ScrollView>
                <VerticalStackLayout Spacing="14">
                    <Border Padding="14" BackgroundColor="{DynamicResource CardBackground}"
                            StrokeThickness="1" Stroke="{DynamicResource BorderColor}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Add friend" FontSize="18" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextPrimary}" />
                            <Entry Placeholder="Friend email" Text="{Binding FriendEmail}"
                                   Keyboard="Email"
                                   BackgroundColor="{DynamicResource PageBackground}"
                                   TextColor="{DynamicResource TextPrimary}"/>
                            <Button Text="Add Friend" Command="{Binding AddFriendCommand}"
                                    BackgroundColor="{DynamicResource Primary}"
                                    TextColor="White" CornerRadius="12" />
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="Refresh Friends" Command="{Binding LoadFriendsCommand}"
                            BackgroundColor="{DynamicResource PrimaryLight}"
                            TextColor="{DynamicResource PrimaryText}" CornerRadius="12" />

                    <Label Text="{Binding StatusMessage}"
                           TextColor="{DynamicResource Primary}" />

                    <CollectionView x:Name="FriendsList" ItemsSource="{Binding Friends}">
                        <CollectionView.EmptyView>
                            <Label Text="No friends yet." Padding="0,40"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14" Margin="0,6"
                                        BackgroundColor="{DynamicResource CardBackground}"
                                        StrokeThickness="1" Stroke="{DynamicResource BorderColor}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding FullName}" FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource TextPrimary}" />
                                            <Label Text="{Binding Email}" FontSize="13"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="Remove"
                                                Command="{Binding BindingContext.RemoveFriendCommand, Source={x:Reference FriendsList}}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="Transparent" TextColor="#B3261E" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>