<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="White"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,14" BackgroundColor="White">
            <Grid WidthRequest="36" HeightRequest="36">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}"/>
                </Grid.GestureRecognizers>
                <Ellipse Stroke="#E0E0E0" StrokeThickness="1.5" Fill="Transparent"
                         WidthRequest="36" HeightRequest="36"
                         HorizontalOptions="Center" VerticalOptions="Center"/>
                <Path Data="M 20,18 L 15,12 L 20,6" Stroke="#111" StrokeThickness="2"
                      StrokeLineCap="Round" StrokeLineJoin="Round"
                      WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Start" VerticalOptions="Center">
                    <Path.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Path.GestureRecognizers>
                </Path>
            </Grid>
            <Label Grid.Column="1" Text="Известия" FontSize="15" FontAttributes="Bold"
                   TextColor="#111" HorizontalOptions="Center" VerticalOptions="Center"/>
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36" Color="Transparent"/>
        </Grid>

        <BoxView Grid.Row="0" HeightRequest="0.5" BackgroundColor="#F0F0F0" VerticalOptions="End"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="{DynamicResource Primary}" Margin="0,8"/>

                <Grid ColumnDefinitions="*,Auto" Padding="16,12,16,8">
                    <Label Text="{Binding HeaderText}" FontSize="12" TextColor="#888888"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="1" BackgroundColor="{DynamicResource PrimaryLight}"
                            Padding="12,6" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MarkAllAsReadCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Прочети всички" FontSize="12" FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}"/>
                    </Border>
                </Grid>

                <Label Text="{Binding StatusMessage}" TextColor="{DynamicResource Primary}"
                       FontSize="12" Margin="16,0,16,8"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringToBoolConverter}}"/>

                <CollectionView x:Name="NotificationsList" ItemsSource="{Binding Notifications}"
                                Margin="16,0,16,24">
                    <CollectionView.EmptyView>
                        <Label Text="Няма известия все още." Padding="0,48"
                               HorizontalTextAlignment="Center" TextColor="#888888" FontSize="13"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="0,0,0,10"
                                    BackgroundColor="White" StrokeThickness="1" Stroke="#F0F0F0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.OpenNotificationCommand, Source={x:Reference NotificationsList}}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border WidthRequest="10" HeightRequest="10"
                                            BackgroundColor="{DynamicResource Primary}"
                                            StrokeThickness="0" VerticalOptions="Start" Margin="0,4,0,0"
                                            IsVisible="{Binding IsRead, Converter={StaticResource InverseBoolConverter}}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="5"/>
                                        </Border.StrokeShape>
                                    </Border>
                                    <BoxView WidthRequest="10" HeightRequest="10" Color="Transparent"
                                             VerticalOptions="Start" IsVisible="{Binding IsRead}"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold"
                                               TextColor="#111111"/>
                                        <Label Text="{Binding Message}" FontSize="12" TextColor="#555555"/>
                                        <Label Text="{Binding TimeText}" FontSize="11" TextColor="#AAAAAA"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>