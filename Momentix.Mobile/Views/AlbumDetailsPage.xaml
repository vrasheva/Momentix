<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.AlbumDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="White"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="16,14" BackgroundColor="White">
            <Grid WidthRequest="36" HeightRequest="36">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}"/>
                </Grid.GestureRecognizers>
                <Ellipse Stroke="#E0E0E0" StrokeThickness="1.5"
                     Fill="Transparent"
                     WidthRequest="36" HeightRequest="36"
                     HorizontalOptions="Center" VerticalOptions="Center"/>
                <Path Grid.Column="0"
                      Data="M 20,18 L 15,12 L 20,6"
                      Stroke="#111" StrokeThickness="2"
                      StrokeLineCap="Round" StrokeLineJoin="Round"
                      WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Start" VerticalOptions="Center">
                    <Path.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Path.GestureRecognizers>
                </Path>
            </Grid>
            <Label Grid.Column="1" Text="{Binding AlbumTitle}"
                   FontSize="15" FontAttributes="Bold" TextColor="#111"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <BoxView Grid.Column="2" WidthRequest="36" HeightRequest="36"
                     Color="Transparent"/>
        </Grid>

        <BoxView Grid.Row="0" HeightRequest="0.5" BackgroundColor="#F0F0F0"
                 VerticalOptions="End"/>

        <!-- Tabs -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" BackgroundColor="White">
            <VerticalStackLayout Grid.Column="0" Spacing="0">
                <Label x:Name="TabPhotos" Text="Снимки"
                       FontSize="13" HorizontalOptions="Center"
                       Padding="0,10" TextColor="#111" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPhotosTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                <BoxView x:Name="UnderlinePhotos" HeightRequest="2"
                         BackgroundColor="#111" Margin="16,0"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="0">
                <Label x:Name="TabMemories" Text="Спомени"
                       FontSize="13" HorizontalOptions="Center"
                       Padding="0,10" TextColor="#888">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMemoriesTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                <BoxView x:Name="UnderlineMemories" HeightRequest="2"
                         BackgroundColor="Transparent" Margin="16,0"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" Spacing="0">
                <Label x:Name="TabMembers" Text="Членове"
                       FontSize="13" HorizontalOptions="Center"
                       Padding="0,10" TextColor="#888">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMembersTapped"/>
                    </Label.GestureRecognizers>
                </Label>
                <BoxView x:Name="UnderlineMembers" HeightRequest="2"
                         BackgroundColor="Transparent" Margin="16,0"/>
            </VerticalStackLayout>
        </Grid>

        <BoxView Grid.Row="1" HeightRequest="0.5" BackgroundColor="#F0F0F0"
                 VerticalOptions="End"/>

        <!-- Content -->
        <Grid Grid.Row="2">

            <!-- Photos Tab -->
            <ScrollView x:Name="PhotosContent" IsVisible="True">
                <VerticalStackLayout Padding="12" Spacing="8">

                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{DynamicResource Primary}"
                           Margin="0,16"/>

                    <!-- Първи ред: бутон + първа снимка -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Grid.Column="0"
                            HeightRequest="160" BackgroundColor="#FAFAFA"
                            StrokeThickness="1.5" Stroke="#CCCCCC">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickPhotoCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Center" Spacing="4">
                                <Label Text="+" FontSize="28" TextColor="#AAAAAA"
                                    HorizontalOptions="Center"/>
                                <Label Text="Добави снимка" FontSize="12"
                                   TextColor="#AAAAAA" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                HeightRequest="160" StrokeThickness="0"
                                IsVisible="{Binding HasPhotos}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Image Source="{Binding FirstPhoto.Url}" Aspect="AspectFill"/>
                        </Border>
                    </Grid>

                    <!-- Останалите снимки -->
                    <CollectionView ItemsSource="{Binding RestPhotos}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="8"
                                 VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="4" Padding="0,0,0,4">
                                    <Border HeightRequest="160" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding Url}" Aspect="AspectFill"/>
                                    </Border>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Memories Tab -->
            <ScrollView x:Name="MemoriesContent" IsVisible="False">
                <VerticalStackLayout Padding="16" Spacing="10">

                    <!-- Добави спомен — ПЪРВИ -->
                    <Label Text="Добави спомен" FontSize="13"
                           FontAttributes="Bold" TextColor="#111" Margin="0,4,0,4"/>
                    <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E0E0E0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Editor Placeholder="Напиши спомен или писмо..."
                                Text="{Binding LetterText}"
                                MinimumHeightRequest="44"
                                AutoSize="TextChanges"
                                Margin="10,8"
                                TextColor="#111" PlaceholderColor="#BBBBBB"
                                BackgroundColor="Transparent"/>
                    </Border>
                    <Button Text="Добави" Command="{Binding AddLetterCommand}"
                            BackgroundColor="{DynamicResource Primary}"
                            TextColor="White"
                            HeightRequest="46" CornerRadius="12"
                            FontAttributes="Bold" FontSize="14"
                            Margin="0,0,0,8"/>

                    <Label Text="{Binding StatusMessage}"
                           TextColor="#E24B4A" FontSize="12"
                           HorizontalOptions="Center"/>

                    <!-- Спомени списък -->
                    <CollectionView ItemsSource="{Binding MediaItems}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="10" Margin="0,0,0,10">

                                    <!-- Заключено писмо -->
                                    <Border IsVisible="{Binding IsLockedLetter}"
                                            BackgroundColor="#2C2C2A"
                                            StrokeThickness="0" Padding="16">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14"/>
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="6"
                                                             HorizontalOptions="Center">
                                            <Label Text="🔒" FontSize="24"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="{Binding CountdownText}"
                                                   FontSize="22" FontAttributes="Bold"
                                                   TextColor="#FAC775"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="{Binding UnlockDateText}"
                                                   FontSize="12" TextColor="#888780"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- Отключено писмо -->
                                    <Border IsVisible="{Binding IsUnlockedLetter}"
                                            BackgroundColor="White"
                                            StrokeThickness="0.5"
                                            Stroke="#E0E0E0" Padding="14">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14"/>
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding UploadedByName, StringFormat='Писмо от {0}'}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="#111"/>
                                            <Label Text="{Binding UploadedAtText}"
                                                   FontSize="11" TextColor="#888"
                                                   Margin="0,0,0,6"/>
                                            <Label Text="{Binding Url}"
                                                   FontSize="13" TextColor="#444"
                                                   LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- Снимка в спомени -->
                                    <VerticalStackLayout IsVisible="{Binding IsImage}"
                                                         Spacing="4">
                                        <Border HeightRequest="160" StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Image Source="{Binding Url}" Aspect="AspectFill"/>
                                        </Border>
                                        <Label Text="{Binding UploadedByName, StringFormat='Качено от {0}'}"
                                               FontSize="11" TextColor="#888"/>
                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Няма спомени все още."
                                   Padding="0,16"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#888" FontSize="13"/>
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Members Tab -->
            <ScrollView x:Name="MembersContent" IsVisible="False">
                <VerticalStackLayout Padding="16" Spacing="0">

                    <!-- Добави член — ПЪРВИ -->
                    <Border Margin="0,8,0,4" BackgroundColor="White"
                            StrokeThickness="0.5" Stroke="#E0E0E0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddMemberTapped"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10"
                              Padding="14,12">
                            <Label Text="+" FontSize="20" TextColor="#888"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Добави член"
                                   FontSize="13" TextColor="#888"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Add member panel -->
                    <VerticalStackLayout x:Name="AddMemberPanel"
                                         IsVisible="False" Spacing="8"
                                         Margin="0,0,0,12">
                        <Border BackgroundColor="White" StrokeThickness="1"
                                Stroke="#E0E0E0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Имейл на приятел..."
                                   Text="{Binding MemberEmail}"
                                   Keyboard="Email" Margin="10,0"
                                   HeightRequest="44"
                                   TextColor="#111" PlaceholderColor="#BBBBBB"
                                   BackgroundColor="Transparent"/>
                        </Border>
                        <Button Text="Добави" Command="{Binding AddMemberCommand}"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="White"
                                HeightRequest="46" CornerRadius="12"
                                FontAttributes="Bold" FontSize="14"/>
                        <Label Text="{Binding StatusMessage}"
                               TextColor="#E24B4A" FontSize="12"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Членове списък -->
                    <CollectionView ItemsSource="{Binding Members}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12" Padding="0,10">
                                        <Border WidthRequest="38" HeightRequest="38"
                                                BackgroundColor="#EEEDFE"
                                                StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="19"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Initials}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="#534AB7"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             VerticalOptions="Center"
                                                             Spacing="2">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="#111"/>
                                            <Label Text="{Binding RoleText}"
                                                   FontSize="11" TextColor="#888"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="👑"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding IsOwner}"/>
                                    </Grid>
                                    <BoxView HeightRequest="0.5"
                                             BackgroundColor="#F0F0F0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Няма членове все още."
                                   Padding="0,32"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#888" FontSize="13"/>
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>