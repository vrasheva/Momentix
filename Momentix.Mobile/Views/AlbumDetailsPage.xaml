<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.AlbumDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Album"
    BackgroundColor="#F6F4EF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button
                    Text="Back"
                    Command="{Binding BackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6750A4" />
                <Label
                    Grid.Column="1"
                    Text="{Binding AlbumTitle}"
                    FontSize="26"
                    FontAttributes="Bold"
                    VerticalOptions="Center"
                    TextColor="#1D1B20" />
            </Grid>

            <Frame Padding="14" CornerRadius="8" BackgroundColor="White" BorderColor="#E7E0EC">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Share album" FontSize="18" FontAttributes="Bold" TextColor="#1D1B20" />
                    <Entry
                        Placeholder="User email"
                        Text="{Binding MemberEmail}"
                        Keyboard="Email"
                        BackgroundColor="#F6F4EF" />
                    <HorizontalStackLayout Spacing="8">
                        <CheckBox IsChecked="{Binding CanUpload}" />
                        <Label Text="Can upload" VerticalOptions="Center" TextColor="#49454F" />
                    </HorizontalStackLayout>
                    <Button
                        Text="Add Member"
                        Command="{Binding AddMemberCommand}"
                        BackgroundColor="#6750A4"
                        TextColor="White"
                        CornerRadius="8" />
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="14" CornerRadius="8" BackgroundColor="White" BorderColor="#E7E0EC">
                <VerticalStackLayout Spacing="10">
                    <Label Text="New letter memory" FontSize="18" FontAttributes="Bold" TextColor="#1D1B20" />
                    <Editor
                        Placeholder="Write a memory or a letter..."
                        Text="{Binding LetterText}"
                        AutoSize="TextChanges"
                        HeightRequest="120"
                        BackgroundColor="#F6F4EF" />
                    <Button
                        Text="Add Memory"
                        Command="{Binding AddLetterCommand}"
                        BackgroundColor="#386A20"
                        TextColor="White"
                        CornerRadius="8" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding StatusMessage}" TextColor="#6750A4" />

            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#6750A4" />

            <Label Text="Memories" FontSize="20" FontAttributes="Bold" TextColor="#1D1B20" />

            <CollectionView ItemsSource="{Binding MediaItems}">
                <CollectionView.EmptyView>
                    <Label
                        Text="No memories in this album yet."
                        Padding="0,24"
                        HorizontalTextAlignment="Center"
                        TextColor="#625B71" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            Padding="14"
                            Margin="0,6"
                            CornerRadius="8"
                            BackgroundColor="White"
                            BorderColor="#E7E0EC">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Type}" FontSize="13" TextColor="#6750A4" />
                                <Label Text="{Binding Url}" FontSize="16" TextColor="#1D1B20" />
                                <Label
                                    Text="{Binding UploadedByName, StringFormat='By: {0}'}"
                                    FontSize="13"
                                    TextColor="#625B71" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
