<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.TimeCapsulesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Capsules"
    BackgroundColor="{DynamicResource PageBackground}">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="16">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label Text="Time Capsules" FontSize="28" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />
                <Label Text="Locked memories with a live countdown"
                       FontSize="13" TextColor="{DynamicResource TextSecondary}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="Logout" Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent" TextColor="{DynamicResource Primary}" />
        </Grid>

        <RefreshView Grid.Row="1" Command="{Binding LoadCapsulesCommand}"
                     IsRefreshing="{Binding IsLoading}">
            <ScrollView>
                <VerticalStackLayout Spacing="14">
                    <Button Text="New Capsule" Command="{Binding GoToCreateCapsuleCommand}"
                            BackgroundColor="{DynamicResource Primary}"
                            TextColor="White" CornerRadius="12" HeightRequest="50" />

                    <Label Text="{Binding ErrorMessage}" TextColor="#B3261E" />

                    <CollectionView ItemsSource="{Binding Capsules}">
                        <CollectionView.EmptyView>
                            <Label Text="No capsules yet." Padding="0,48"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16" Margin="0,6"
                                        BackgroundColor="{DynamicResource CardBackground}"
                                        StrokeThickness="1" Stroke="{DynamicResource BorderColor}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Title}" FontSize="20"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource TextPrimary}" />
                                            <Label Grid.Column="1" Text="{Binding StatusText}"
                                                   FontSize="13"
                                                   TextColor="{DynamicResource Primary}" />
                                        </Grid>
                                        <Label Text="{Binding Description}" FontSize="14"
                                               TextColor="{DynamicResource TextSecondary}" />
                                        <Label Text="{Binding CountdownText}" FontSize="24"
                                               FontAttributes="Bold" TextColor="#386A20" />
                                        <Label Text="{Binding UnlockDateText}" FontSize="13"
                                               TextColor="{DynamicResource TextSecondary}" />
                                        <Grid ColumnDefinitions="*,*">
                                            <Label Text="{Binding MemberCount, StringFormat='Members: {0}'}"
                                                   FontSize="13" TextColor="{DynamicResource TextSecondary}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding MediaCount, StringFormat='Media: {0}'}"
                                                   FontSize="13" HorizontalTextAlignment="End"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>