<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.CreateTimeCapsulePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="New Capsule"
    BackgroundColor="#F6F4EF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label
                Text="New Time Capsule"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#1D1B20" />

            <Entry
                Placeholder="Capsule title"
                Text="{Binding Title}"
                BackgroundColor="White"
                HeightRequest="52" />

            <Editor
                Placeholder="Description"
                Text="{Binding Description}"
                AutoSize="TextChanges"
                BackgroundColor="White"
                HeightRequest="120" />

            <Label Text="Unlock date" FontAttributes="Bold" TextColor="#1D1B20" />
            <DatePicker Date="{Binding UnlockDate}" BackgroundColor="White" HeightRequest="52" />

            <Label Text="Unlock time" FontAttributes="Bold" TextColor="#1D1B20" />
            <TimePicker Time="{Binding UnlockTime}" BackgroundColor="White" HeightRequest="52" />

            <Frame Padding="14" CornerRadius="8" BackgroundColor="White" BorderColor="#E7E0EC">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Capsule photos" FontSize="18" FontAttributes="Bold" TextColor="#1D1B20" />
                    <Label Text="{Binding SelectedPhotoCountText}" FontSize="13" TextColor="#625B71" />
                    <Button
                        Text="Add Photo"
                        Command="{Binding PickPhotoCommand}"
                        BackgroundColor="#EADDFF"
                        TextColor="#21005D"
                        CornerRadius="8" />

                    <CollectionView x:Name="SelectedPhotosList" ItemsSource="{Binding SelectedPhotos}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="0,4">
                                    <Label
                                        Text="{Binding FileName}"
                                        FontSize="13"
                                        VerticalOptions="Center"
                                        TextColor="#49454F" />
                                    <Button
                                        Grid.Column="1"
                                        Text="Remove"
                                        Command="{Binding BindingContext.RemovePhotoCommand, Source={x:Reference SelectedPhotosList}}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#B3261E" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="14" CornerRadius="8" BackgroundColor="White" BorderColor="#E7E0EC">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Invite friends" FontSize="18" FontAttributes="Bold" TextColor="#1D1B20" />
                    <Label Text="Selected friends will be able to see this capsule." FontSize="13" TextColor="#625B71" />

                    <CollectionView x:Name="FriendsList" ItemsSource="{Binding Friends}" MaximumHeightRequest="220">
                        <CollectionView.EmptyView>
                            <Label
                                Text="No friends yet. Add friends first from the Friends tab."
                                Padding="0,12"
                                TextColor="#625B71" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="0,6">
                                    <CheckBox
                                        IsChecked="{Binding IsInvited}"
                                        VerticalOptions="Center"
                                        Color="#6750A4" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label
                                            Text="{Binding FullName}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="#1D1B20" />
                                        <Label
                                            Text="{Binding Email}"
                                            FontSize="12"
                                            TextColor="#625B71" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>
            <Label Text="{Binding ErrorMessage}" TextColor="#B3261E" />

            <ActivityIndicator
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#6750A4" />

            <Button
                Text="Save Capsule"
                Command="{Binding SaveCommand}"
                BackgroundColor="#6750A4"
                TextColor="White"
                HeightRequest="52"
                CornerRadius="8" />

            <Button
                Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="Transparent"
                TextColor="#6750A4" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
