<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.ChallengesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Challenge"
    BackgroundColor="{DynamicResource PageBackground}">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Daily Challenge" FontSize="28" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />

                <Border Padding="16" BackgroundColor="{DynamicResource CardBackground}"
                        StrokeThickness="1" Stroke="{DynamicResource BorderColor}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding ChallengeTitle}" FontSize="22"
                               FontAttributes="Bold" TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="{Binding RevealText}" FontSize="14"
                               TextColor="{DynamicResource TextSecondary}" />
                        <Label
                            Text="{Binding SelectedPhotoName}"
                            FontSize="13"
                            TextColor="{DynamicResource TextSecondary}" />
                        <Button
                            Text="Pick Photo"
                            Command="{Binding PickPhotoCommand}"
                            BackgroundColor="{DynamicResource PrimaryLight}"
                            TextColor="{DynamicResource PrimaryText}"
                            CornerRadius="12" />
                        <Editor Placeholder="Optional caption..."
                                Text="{Binding SubmissionText}" AutoSize="TextChanges"
                                HeightRequest="80"
                                BackgroundColor="{DynamicResource PageBackground}"
                                TextColor="{DynamicResource TextPrimary}"/>
                        <Button Text="Submit" Command="{Binding SubmitCommand}"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="White" CornerRadius="12" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding StatusMessage}"
                       TextColor="{DynamicResource Primary}" />

                <Label Text="Feed" FontSize="20" FontAttributes="Bold"
                       TextColor="{DynamicResource TextPrimary}" />

                <CollectionView ItemsSource="{Binding Submissions}">
                    <CollectionView.EmptyView>
                        <Label Text="No submissions yet." Padding="0,24"
                               HorizontalTextAlignment="Center"
                               TextColor="{DynamicResource TextSecondary}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Margin="0,6"
                                    BackgroundColor="{DynamicResource CardBackground}"
                                    StrokeThickness="1" Stroke="{DynamicResource BorderColor}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding UserName}" FontAttributes="Bold"
                                           TextColor="{DynamicResource TextPrimary}" />
                                    <Image
                                        Source="{Binding MediaUrl}"
                                        Aspect="AspectFill"
                                        HeightRequest="240"
                                        BackgroundColor="{DynamicResource PageBackground}" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label Text="{Binding VoteCount, StringFormat='Votes: {0}'}"
                                               FontSize="13" TextColor="{DynamicResource TextSecondary}" />
                                        <Button Grid.Column="1" Text="Vote"
                                                Command="{Binding BindingContext.VoteCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{DynamicResource PrimaryDark}"
                                                TextColor="White" CornerRadius="8" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
