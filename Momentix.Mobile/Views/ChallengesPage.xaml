<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.ChallengesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Challenge"
    BackgroundColor="#F6F4EF">

    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label
                    Text="Daily Challenge"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#1D1B20" />

                <Frame Padding="16" CornerRadius="8" BackgroundColor="White" BorderColor="#E7E0EC">
                    <VerticalStackLayout Spacing="10">
                        <Label
                            Text="{Binding ChallengeTitle}"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#1D1B20" />
                        <Label
                            Text="{Binding RevealText}"
                            FontSize="14"
                            TextColor="#625B71" />
                        <Editor
                            Placeholder="Describe your photo or paste an image link..."
                            Text="{Binding SubmissionText}"
                            AutoSize="TextChanges"
                            HeightRequest="110"
                            BackgroundColor="#F6F4EF" />
                        <Button
                            Text="Submit"
                            Command="{Binding SubmitCommand}"
                            BackgroundColor="#6750A4"
                            TextColor="White"
                            CornerRadius="8" />
                    </VerticalStackLayout>
                </Frame>

                <Label Text="{Binding StatusMessage}" TextColor="#6750A4" />

                <Label Text="Feed" FontSize="20" FontAttributes="Bold" TextColor="#1D1B20" />

                <CollectionView ItemsSource="{Binding Submissions}">
                    <CollectionView.EmptyView>
                        <Label
                            Text="No submissions yet."
                            Padding="0,24"
                            HorizontalTextAlignment="Center"
                            TextColor="#625B71" />
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame
                                Padding="14"
                                Margin="0,6"
                                CornerRadius="8"
                                BackgroundColor="White"
                                BorderColor="#E7E0EC">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding UserName}" FontAttributes="Bold" TextColor="#1D1B20" />
                                    <Label Text="{Binding MediaUrl}" TextColor="#49454F" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <Label
                                            Text="{Binding VoteCount, StringFormat='Votes: {0}'}"
                                            FontSize="13"
                                            TextColor="#625B71" />
                                        <Button
                                            Grid.Column="1"
                                            Text="Vote"
                                            Command="{Binding BindingContext.VoteCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#386A20"
                                            TextColor="White"
                                            CornerRadius="8" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
