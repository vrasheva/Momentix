<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.AlbumsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Albums">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Grid ColumnDefinitions="*,Auto">
            <Label
                Text="My Albums"
                FontSize="28"
                FontAttributes="Bold"
                VerticalOptions="Center" />

            <Button
                Grid.Column="1"
                Text="Logout"
                Command="{Binding LogoutCommand}" />
        </Grid>

        <Button
            Text="Load Albums"
            Command="{Binding LoadAlbumsCommand}" />

        <Button
            Text="Create Album"
            Command="{Binding GoToCreateAlbumCommand}" />

        <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}" />

        <Label
            Text="{Binding ErrorMessage}"
            TextColor="Red" />

        <CollectionView ItemsSource="{Binding Albums}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        Padding="15"
                        Margin="0,5"
                        CornerRadius="12">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="{Binding Title}"
                                FontSize="20"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding Description}"
                                FontSize="14" />

                            <Label
                                Text="{Binding OwnerName}"
                                FontSize="13" />

                            <Label
                                Text="{Binding MemberCount, StringFormat='Members: {0}'}"
                                FontSize="13" />

                            <Label
                                Text="{Binding MediaCount, StringFormat='Media: {0}'}"
                                FontSize="13" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>