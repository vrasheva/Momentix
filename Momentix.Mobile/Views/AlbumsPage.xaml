<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Momentix.Mobile.Views.AlbumsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Albums"
    BackgroundColor="{DynamicResource PageBackground}">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label
                    Text="Momentix Albums"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="{DynamicResource TextPrimary}" />
                <Label
                    Text="This is the updated mobile build"
                    FontSize="13"
                    TextColor="{DynamicResource TextSecondary}" />
            </VerticalStackLayout>

            <Button
                Grid.Column="1"
                Text="Logout"
                Command="{Binding LogoutCommand}"
                BackgroundColor="Transparent"
                TextColor="{DynamicResource Primary}" />
        </Grid>

        <Button
            Text="Refresh Albums"
            Command="{Binding LoadAlbumsCommand}"
            BackgroundColor="{DynamicResource PrimaryLight}"
            TextColor="{DynamicResource PrimaryText}"
            CornerRadius="12" />

        <Button
            Text="Create Album"
            Command="{Binding GoToCreateAlbumCommand}"
            BackgroundColor="{DynamicResource Primary}"
            TextColor="White"
            CornerRadius="12" />

        <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            Color="{DynamicResource Primary}" />

        <Label
            Text="{Binding ErrorMessage}"
            TextColor="#B3261E" />

        <CollectionView
            x:Name="AlbumsList"
            ItemsSource="{Binding Albums}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Padding="15"
                        Margin="0,5"
                        BackgroundColor="{DynamicResource CardBackground}"
                        StrokeThickness="1"
                        Stroke="{DynamicResource BorderColor}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.OpenAlbumCommand, Source={x:Reference AlbumsList}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="10">
                            <Label
                                Text="{Binding Title}"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="{DynamicResource TextPrimary}" />

                            <Label
                                Text="{Binding Description}"
                                FontSize="14"
                                TextColor="{DynamicResource TextSecondary}" />

                            <Label
                                Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                FontSize="13"
                                TextColor="{DynamicResource TextSecondary}" />

                            <Grid ColumnDefinitions="*,*">
                                <Label
                                    Text="{Binding MemberCount, StringFormat='Members: {0}'}"
                                    FontSize="13"
                                    TextColor="{DynamicResource TextSecondary}" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding MediaCount, StringFormat='Media: {0}'}"
                                    FontSize="13"
                                    HorizontalTextAlignment="End"
                                    TextColor="{DynamicResource TextSecondary}" />
                            </Grid>

                            <Button
                                Text="Open Album"
                                Command="{Binding BindingContext.OpenAlbumCommand, Source={x:Reference AlbumsList}}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="White"
                                CornerRadius="10" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>