<Shell
    x:Class="Momentix.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Momentix.Mobile.Views"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="RegisterPage"
        ContentTemplate="{DataTemplate views:RegisterPage}" />

    <TabBar Route="Home">
        <ShellContent
            Title="Albums"
            Route="AlbumsPage"
            ContentTemplate="{DataTemplate views:AlbumsPage}" />

        <ShellContent
            Title="Capsules"
            Route="TimeCapsulesPage"
            ContentTemplate="{DataTemplate views:TimeCapsulesPage}" />

        <ShellContent
            Title="Challenge"
            Route="ChallengesPage"
            ContentTemplate="{DataTemplate views:ChallengesPage}" />
    </TabBar>

    <ShellContent
        Route="CreateAlbumPage"
        ContentTemplate="{DataTemplate views:CreateAlbumPage}" />

</Shell>
