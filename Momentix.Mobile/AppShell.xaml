<Shell
    x:Class="Momentix.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Momentix.Mobile.Views"
    xmlns:local="clr-namespace:Momentix.Mobile"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="RegisterPage"
        ContentTemplate="{DataTemplate views:RegisterPage}" />

    <ShellContent
        Route="MainPage"
        ContentTemplate="{DataTemplate local:MainPage}" />
    <ShellContent
    Route="AlbumsPage"
    ContentTemplate="{DataTemplate views:AlbumsPage}" />
    <ShellContent
    Route="CreateAlbumPage"
    ContentTemplate="{DataTemplate views:CreateAlbumPage}" />

</Shell>